msgid "No rooms configured. Click to open preferences."
msgstr "Комнаты не настроены. Откройте настройки."

msgid "Preferences"
msgstr "Настройки"

msgid "Toggle popup"
msgstr "Открытие меню"

msgid "Disabled"
msgstr "Отключено"

msgid "Press a shortcut"
msgstr "Нажмите сочетание"

msgid "Press keys… Esc to clear, Backspace to cancel"
msgstr "Нажмите клавиши… Esc — очистить, Backspace — отмена"

msgid "General"
msgstr "Общие"

msgid "Open command (%U = URL)"
msgstr "Команда открытия (%U = URL)"

msgid "Toggle popup shortcut"
msgstr "Хоткей открытия меню"

msgid "Set…"
msgstr "Задать…"

msgid "Rooms"
msgstr "Комнаты"

msgid "Add room"
msgstr "Добавить комнату"

msgid "(corrupt entry — edit via dconf)"
msgstr "(повреждённая запись — отредактируйте через dconf)"

msgid "(unnamed)"
msgstr "(без имени)"

msgid "Move up"
msgstr "Поднять"

msgid "Move down"
msgstr "Опустить"

msgid "Edit"
msgstr "Редактировать"

msgid "Delete"
msgstr "Удалить"

msgid "No rooms yet"
msgstr "Комнат пока нет"

msgid "Click + to add your first room"
msgstr "Нажмите +, чтобы добавить первую комнату"

msgid "Delete room?"
msgstr "Удалить комнату?"

msgid "Cancel"
msgstr "Отмена"

msgid "Edit room"
msgstr "Редактировать комнату"

msgid "Name"
msgstr "Имя"

msgid "URL"
msgstr "Ссылка"

msgid "Shortcut"
msgstr "Хоткей"

msgid "None"
msgstr "Нет"

msgid "Save"
msgstr "Сохранить"

msgid "Name is required"
msgstr "Имя обязательно"

msgid "Shortcut must include at least one modifier"
msgstr "Хоткей должен содержать хотя бы один модификатор"

msgid "Shortcut conflicts with the popup toggle shortcut"
msgstr "Хоткей конфликтует с хоткеем открытия меню"

msgid "Shortcut already used by \"%s\""
msgstr "Хоткей уже используется в \"%s\""

msgid "\"%s\" will be removed."
msgstr "\"%s\" будет удалена."

msgid "Hotkey %s already in use — \"%s\""
msgstr "Хоткей %s уже занят — \"%s\""

msgid "Invalid URL for \"%s\": %s"
msgstr "Некорректный URL для \"%s\": %s"

msgid "Failed to open \"%s\": %s"
msgstr "Не удалось открыть \"%s\": %s"

msgid "URL is empty"
msgstr "URL пустой"

msgid "Malformed URL"
msgstr "Некорректный URL"

msgid "Only http(s) URLs are supported"
msgstr "Поддерживаются только http(s) URL"

msgid "URL has no host"
msgstr "В URL отсутствует хост"
