msgid "Invalid URL for \"${room.name}\": ${check.reason}"
msgstr "Некорректный URL для \"${room.name}\": ${check.reason}"

#: lib/launcher.js:55
msgid "Failed to open \"${room.name}\": ${e.message}"
msgstr "Не удалось открыть \"${room.name}\": ${e.message}"

#: lib/rooms.js:21
msgid "URL is empty"
msgstr "URL пустой"

#: lib/rooms.js:26
msgid "Malformed URL"
msgstr "Некорректный URL"

#: lib/rooms.js:30
msgid "Only http(s) URLs are supported"
msgstr "Поддерживаются только http(s) URL"

#: lib/rooms.js:32
msgid "URL has no host"
msgstr "В URL отсутствует хост"
