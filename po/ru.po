#: prefs.js:137
msgid "(unnamed)"
msgstr "(без имени)"

#: prefs.js:163
msgid "Move up"
msgstr "Поднять"

#: prefs.js:173
msgid "Move down"
msgstr "Опустить"

#: prefs.js:182
msgid "Edit"
msgstr "Редактировать"

#: prefs.js:191 prefs.js:232
msgid "Delete"
msgstr "Удалить"

#: prefs.js:202
msgid "No rooms yet"
msgstr "Комнат пока нет"

#: prefs.js:203
msgid "Click + to add your first room"
msgstr "Нажмите +, чтобы добавить первую комнату"

#: prefs.js:228
msgid "Delete room?"
msgstr "Удалить комнату?"

#: prefs.js:231 prefs.js:298
msgid "Cancel"
msgstr "Отмена"

#: prefs.js:248
msgid "Edit room"
msgstr "Редактировать комнату"

#: prefs.js:262
msgid "Name"
msgstr "Имя"

#: prefs.js:266
msgid "URL"
msgstr "Ссылка"

#: prefs.js:270
msgid "Shortcut"
msgstr "Хоткей"

#: prefs.js:273
msgid "None"
msgstr "Нет"

#: prefs.js:303
msgid "Save"
msgstr "Сохранить"

#: prefs.js:311
msgid "Name is required"
msgstr "Имя обязательно"

#: prefs.js:317
msgid "Shortcut must include at least one modifier"
msgstr "Хоткей должен содержать хотя бы один модификатор"

